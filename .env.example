# Database connection string.
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./data/app.db

# Postgres example:
# DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# Optional: comma separated list of merchant_ids to expose; left blank means all
ALLOWED_MERCHANTS=

# Auto-seed the database with sample_events.json on startup if events table is empty
AUTO_SEED=true
SEED_FILE=sample_events.json

# Server
HOST=0.0.0.0
PORT=8000
