# Database connection string.
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./data/app.db

# Postgres example:
# DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# Auto-seed the database on startup if the events table is empty.
# SEED_FILE is the provided assignment data (used unmodified); SEED_EXTRA_FILE
# is supplemental data adding the remaining discrepancy types.
AUTO_SEED=true
SEED_FILE=sample_events.json
SEED_EXTRA_FILE=sample_events_extra.json

# Server
HOST=0.0.0.0
PORT=8000
