        {
          "name": "Ingest single event",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.variables.set('demo_event_id', pm.variables.replaceIn('{{$guid}}'));",
                  "pm.variables.set('demo_tx_id', pm.variables.replaceIn('{{$guid}}'));",
                  "pm.variables.set('demo_ts', new Date().toISOString());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 202', () => pm.response.to.have.status(202));",
                  "const b = pm.response.json();",
                  "pm.test('accepted 1, duplicates 0', () => { pm.expect(b.received).to.eql(1); pm.expect(b.accepted).to.eql(1); pm.expect(b.duplicates).to.eql(0); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/events",
              "host": ["{{base_url}}"],
              "path": ["events"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"{{demo_event_id}}\",\n  \"event_type\": \"payment_initiated\",\n  \"transaction_id\": \"{{demo_tx_id}}\",\n  \"merchant_id\": \"merchant_1\",\n  \"merchant_name\": \"QuickMart\",\n  \"amount\": 1499.99,\n  \"currency\": \"INR\",\n  \"timestamp\": \"{{demo_ts}}\"\n}"
            }
          }
        },
        {
          "name": "Ingest batch (3 events: initiated → processed → settled)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.variables.set('e1', pm.variables.replaceIn('{{$guid}}'));",
                  "pm.variables.set('e2', pm.variables.replaceIn('{{$guid}}'));",
                  "pm.variables.set('e3', pm.variables.replaceIn('{{$guid}}'));",
                  "pm.variables.set('demo_tx_id', pm.variables.replaceIn('{{$guid}}'));",
                  "var now = Date.now();",
                  "pm.variables.set('t1', new Date(now - 120000).toISOString());",
                  "pm.variables.set('t2', new Date(now - 60000).toISOString());",
                  "pm.variables.set('t3', new Date(now).toISOString());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 202', () => pm.response.to.have.status(202));",
                  "const b = pm.response.json();",
                  "pm.test('accepted 3, duplicates 0', () => { pm.expect(b.accepted).to.eql(3); pm.expect(b.duplicates).to.eql(0); });",
                  "pm.test('per-event results returned', () => { pm.expect(b.results).to.be.an('array').with.lengthOf(3); pm.expect(b.results.every(r => r.status === 'accepted')).to.be.true; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/events?verbose=true",
              "host": ["{{base_url}}"],
              "path": ["events"],
              "query": [{ "key": "verbose", "value": "true" }]
            },
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"event_id\": \"{{e1}}\",\n    \"event_type\": \"payment_initiated\",\n    \"transaction_id\": \"{{demo_tx_id}}\",\n    \"merchant_id\": \"merchant_1\",\n    \"merchant_name\": \"QuickMart\",\n    \"amount\": 2400.00,\n    \"currency\": \"INR\",\n    \"timestamp\": \"{{t1}}\"\n  },\n  {\n    \"event_id\": \"{{e2}}\",\n    \"event_type\": \"payment_processed\",\n    \"transaction_id\": \"{{demo_tx_id}}\",\n    \"merchant_id\": \"merchant_1\",\n    \"merchant_name\": \"QuickMart\",\n    \"amount\": 2400.00,\n    \"currency\": \"INR\",\n    \"timestamp\": \"{{t2}}\"\n  },\n  {\n    \"event_id\": \"{{e3}}\",\n    \"event_type\": \"settled\",\n    \"transaction_id\": \"{{demo_tx_id}}\",\n    \"merchant_id\": \"merchant_1\",\n    \"merchant_name\": \"QuickMart\",\n    \"amount\": 2400.00,\n    \"currency\": \"INR\",\n    \"timestamp\": \"{{t3}}\"\n  }\n]"
            },
            "description": "Sends three events for one transaction. `verbose=true` returns per-event accepted/duplicate status."
          }
        },
        {
          "name": "Duplicate event (idempotency demo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 202', () => pm.response.to.have.status(202));",
                  "const b = pm.response.json();",
                  "// Run twice: 1st call accepted=1, 2nd call duplicates=1. Either way received=1 and exactly one of accepted/duplicates is 1.",
                  "pm.test('received 1', () => pm.expect(b.received).to.eql(1));",
                  "pm.test('idempotent: accepted + duplicates == 1', () => pm.expect(b.accepted + b.duplicates).to.eql(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/events?verbose=true",
              "host": ["{{base_url}}"],
              "path": ["events"],
              "query": [{ "key": "verbose", "value": "true" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"fixed-demo-event-001\",\n  \"event_type\": \"payment_initiated\",\n  \"transaction_id\": \"fixed-demo-tx-001\",\n  \"merchant_id\": \"merchant_3\",\n  \"merchant_name\": \"UrbanEats\",\n  \"amount\": 99.50,\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-06-01T10:00:00Z\"\n}"
            },
            "description": "Run twice. First call returns `accepted=1, duplicates=0`. Second call returns `accepted=0, duplicates=1`."
          }
        },
